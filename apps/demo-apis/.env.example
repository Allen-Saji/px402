# Per-route prices in micro-USDC (1 USDC = 1_000_000).
PX402_PRICE_SENTIMENT=10000
PX402_PRICE_WHALES=20000
PX402_PRICE_RISK=30000

# HMAC secret for signed payment tokens. 32+ bytes of randomness.
# If unset (non-production), the server auto-generates one on boot.
# PX402_SERVER_SECRET=

# Server's receiving wallet (base58). This value is echoed as X-Payment-Address
# and becomes the `to` field on MagicBlock's /v1/spl/transfer. The API derives
# the real recipient ATA from this wallet + the mint.
PX402_PAYMENT_ADDRESS=8AxCJeRrtfwNVQ5huVoF9cto7Y4Jvw6bP1TUUs2ZnK56

# SPL mint accepted as payment (px402 devnet test USDC).
PX402_MINT=5CmxDcDtDiqwxy9TDVyo1Xjr4AFwQzrH7vKr8cXfkEse

# MagicBlock endpoints (override for staging or production).
PX402_API_URL=https://payments.magicblock.app
PX402_BASE_RPC_URL=https://rpc.magicblock.app/devnet
PX402_EPHEMERAL_RPC_URL=https://devnet.magicblock.app
# PX402_EPHEMERAL_WS_URL=wss://devnet.magicblock.app
PX402_VALIDATOR=MAS1Dt9qreoRMQ14YQuhg8UTZMMzDdKhmkZMECCzk57
PX402_CLUSTER=devnet

PORT=8787
