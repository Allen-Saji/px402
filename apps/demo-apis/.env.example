# Path is served at /api/sentiment. One micro-USDC unit = 0.000001 USDC.
PX402_PRICE_SENTIMENT=10000

# HMAC secret for signed payment tokens. 32+ bytes of randomness.
# If unset (non-production), the server auto-generates one on boot.
# PX402_SERVER_SECRET=

# Server's receiving wallet (base58). This is the owner of the destination ATA.
PX402_DESTINATION_WALLET=3wBhCBpCudbtfdaGdBRWhjsRq9B2yAkAgKadjJkVdAiA

# Server's receiving Associated Token Account for the mint (base58).
PX402_DESTINATION_ATA=3PkQ4JM6WWWEpxoaQtFczYgn47ZkMmdFWySSBfGVVh6v

# SPL mint accepted as payment (px402 devnet test USDC).
PX402_MINT=5CmxDcDtDiqwxy9TDVyo1Xjr4AFwQzrH7vKr8cXfkEse

# MagicBlock endpoints (override for staging or production).
PX402_BASE_RPC_URL=https://rpc.magicblock.app/devnet
PX402_EPHEMERAL_RPC_URL=https://devnet.magicblock.app
# WS auto-derives from EPHEMERAL_RPC_URL unless set explicitly.
# PX402_EPHEMERAL_WS_URL=wss://devnet.magicblock.app

PORT=8787
